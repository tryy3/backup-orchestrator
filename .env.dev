# Local development defaults — committed to repo (no secrets here).
# Override by creating .env.dev.local (git-ignored) alongside this file.
#
# Path-dependent vars (BACKUP_DB_PATH, BACKUP_DATA_DIR) are set by justfile
# recipes using justfile_directory() so they are always absolute and correct
# regardless of which directory you run just from.

# ── Server ────────────────────────────────────────────────────────────────────
BACKUP_HTTP_PORT=8080
BACKUP_GRPC_PORT=8443

# ── Agent ─────────────────────────────────────────────────────────────────────
BACKUP_SERVER_URL=localhost:8443
BACKUP_AGENT_NAME=dev-agent
